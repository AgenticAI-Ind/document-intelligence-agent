# Document Intelligence Agent Configuration

# Application
APP_NAME="Document Intelligence Agent"
APP_VERSION="1.0.0"
ENV="development"
DEBUG=true
LOG_LEVEL="INFO"

# Server
HOST="0.0.0.0"
PORT=8000

# Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# ChromaDB Vector Store
CHROMA_PERSIST_DIRECTORY="./data/chroma"

# Document Processing
MAX_FILE_SIZE_MB=50
SUPPORTED_FORMATS=pdf,docx,xlsx,pptx,txt,csv,md

# AI Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RELEVANT_CHUNKS=3

# Feature Flags
ENABLE_TRANSFORMER_NER=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_DOCUMENT_COMPARISON=true
